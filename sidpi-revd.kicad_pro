<?xml version="1.0" encoding="UTF-8"?>
<project>
  <title>SidPi Rev d</title>
  <date>2026-04-16</date>
  <tool>KiCad PCBNew 6.0</tool>
  
  <general>
    <source>schematic/sidpi-revd.brd</source>
    <sheet>SidPi Rev d</sheet>
    <title>SidPi - MOS 6581 SID Interface for Raspberry Pi</title>
    <company>Jamie Nuttall 2014-2026</company>
    <desc>Raspberry Pi HAT that interfaces a MOS 6581 SID chip for audio synthesis. Features 74HCT245 level shifters, MT3608 boost converter (5V→12V), and SMD optimization.</desc>
  </general>
  
  <settings>
    <page>A4</page>
    <paper-size>mm</paper-size>
    <unit>millimeters</unit>
    <grid>0.25mm</grid>
    <snapping>enabled</snapping>
    <autorouter>
      <strategy>Default</strategy>
    </autorouter>
  </settings>
  
  <classes>
    <class name="default" width="0.25" clearance="0.25">
      <net>DATA_BUS</net>
      <net>ADDR_BUS</net>
      <net>CONTROL</net>
    </class>
    <class name="VCC_5V" width="0.5" clearance="0.25">
      <net>VCC</net>
      <net>+3V3</net>
    </class>
    <class name="VDD_12V" width="0.5" clearance="0.25">
      <net>VDD</net>
    </class>
  </classes>
  
  <netlist>
    <net name="+3V3">
      <part SK1:1</part>
      <part SK1:17</part>
      <part U2:1</part>
      <part U3:1</part>
